generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  passwordHash       String
  name               String
  organizationMembers OrganizationMember[]
  comments           Comment[]
  activityLogs       ActivityLog[]
  tasks              Task[]
  createdAt          DateTime             @default(now())
}

model Organization {
  id          String               @id @default(cuid())
  name        String
  members     OrganizationMember[]
  projects    Project[]
  subscription Subscription?
  createdAt   DateTime             @default(now())
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
}

model Project {
  id                 String              @id @default(cuid())
  organizationId     String
  name               String
  objective          String
  goal               String
  organization       Organization        @relation(fields: [organizationId], references: [id])
  boundaries         ProjectBoundary[]
  landProfile        LandProfile?
  layoutOptions      LayoutOption[]
  optimizationScores OptimizationScore[]
  feasibilityReports FeasibilityReport[]
  recommendations    AIRecommendation[]
  comments           Comment[]
  activityLogs       ActivityLog[]
  exports            Export[]
  payments           Payment[]
  tasks              Task[]
  createdAt          DateTime            @default(now())
}

model ProjectBoundary { id String @id @default(cuid()) projectId String geometry Json project Project @relation(fields:[projectId], references:[id]) }
model LandProfile { id String @id @default(cuid()) projectId String @unique zoning String? constraints Json? project Project @relation(fields:[projectId], references:[id]) }
model LayoutOption { id String @id @default(cuid()) projectId String scenarioType String payload Json project Project @relation(fields:[projectId], references:[id]) }
model OptimizationScore { id String @id @default(cuid()) projectId String layoutOptionId String score Float breakdown Json project Project @relation(fields:[projectId], references:[id]) }
model FeasibilityReport { id String @id @default(cuid()) projectId String summary String payload Json project Project @relation(fields:[projectId], references:[id]) }
model AIRecommendation { id String @id @default(cuid()) projectId String audience String payload Json project Project @relation(fields:[projectId], references:[id]) }
model Comment { id String @id @default(cuid()) projectId String userId String body String scenarioId String? project Project @relation(fields:[projectId], references:[id]) user User @relation(fields:[userId], references:[id]) createdAt DateTime @default(now()) }
model ActivityLog { id String @id @default(cuid()) projectId String userId String action String payload Json? project Project @relation(fields:[projectId], references:[id]) user User @relation(fields:[userId], references:[id]) createdAt DateTime @default(now()) }
model Export { id String @id @default(cuid()) projectId String type String isUnlocked Boolean @default(false) url String? metadata Json? project Project @relation(fields:[projectId], references:[id]) createdAt DateTime @default(now()) }
model Payment { id String @id @default(cuid()) projectId String reference String @unique provider String status String amount Int metadata Json? project Project @relation(fields:[projectId], references:[id]) createdAt DateTime @default(now()) }
model Subscription { id String @id @default(cuid()) organizationId String @unique plan String status String renewalDate DateTime organization Organization @relation(fields:[organizationId], references:[id]) }
model Listing { id String @id @default(cuid()) organizationId String title String payload Json status String }
model Opportunity { id String @id @default(cuid()) title String type String payload Json status String }
model Task { id String @id @default(cuid()) projectId String userId String title String status String dueDate DateTime? project Project @relation(fields:[projectId], references:[id]) user User @relation(fields:[userId], references:[id]) }
